# Шаблон. Реальний `.env-runpod` тримай у `$HOME`, chmod 600, у git НЕ йде.
#
# Для CLI:
#   cp .env-runpod.example ~/.env-runpod
#   chmod 600 ~/.env-runpod
#   nano ~/.env-runpod
#   source ~/.env-runpod
#
# Використовується ТІЛЬКИ для локальних RunPod CLI / API дзвінків.
# HF_TOKEN на pod передається через RunPod web UI ("Pod env vars"),
# НЕ через цей файл.

RUNPOD_API_KEY=
